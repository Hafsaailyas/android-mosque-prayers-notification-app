```mermaid
flowchart TD
    API["🌐 Remote API\nPrayer times · reminder configs\nsync interval · broadcast msgs"]

    subgraph SYNC["Background Sync Layer"]
        PW["PeriodicWorkRequest\nserver-controlled interval"]
        BOOT["BOOT_COMPLETED\nBroadcastReceiver"]
        SW["SyncWorker\nCoroutineWorker\n─────────────────\n1. Validate auth token\n2. HTTP GET w/ Bearer token\n3. Process urgent messages\n4. Save response to prefs\n5. Save sync_after interval\n6. Trigger orchestration"]
        DRW["DailyRescheduleWorker\nevery 24 hours\nRe-schedules for new day"]
    end

    subgraph ORCH["Reminder Orchestration Layer"]
        PARSE["Parse JSON → typed structures"]
        VALIDATE["Validate trigger times\nreject past · reject > 30 days"]
        CONFLICT["Build conflict set\nSet of occupied HH:mm slots"]
    end

    subgraph NOTIF["Notification Delivery Layer"]
        SNW["Standard Notification Worker\nNotificationCompat · PRIORITY_HIGH\nplayAudio = true/false"]
        FSW["Full-Screen Alert Worker\nFLAG_SHOW_WHEN_LOCKED\nFLAG_TURN_SCREEN_ON\nUSE_FULL_SCREEN_INTENT"]
    end

    subgraph AUDIO["Audio Management Layer"]
        AAM["AudioAlertManager\nUSAGE_NOTIFICATION_EVENT\nRespects silent mode\nPlays once"]
        FSAM["FullScreenAudioManager\nUSAGE_ALARM\nBypasses silent mode\nLoops until dismissed"]
    end

    subgraph PERMS["Permission Layer"]
        PS["PermissionStatus\nhasFullScreenIntent\ncanDrawOverlays\nignoringBatteryOptimization"]
        OB["Permission Onboarding\nJetpack Compose\n24-hour skip window"]
    end

    PREFS[("SharedPreferences\nnamazi_response\nsync_after · token\nskip_window_start")]

    API -->|HTTP GET| SW
    PW --> SW
    BOOT --> SW
    SW --> DRW
    SW --> PARSE
    SW --> PREFS
    PARSE --> VALIDATE
    VALIDATE --> CONFLICT
    CONFLICT -->|playAudio flag| SNW
    CONFLICT --> FSW
    SNW -->|audio enabled| AAM
    FSW --> FSAM
    PS --> OB
    OB --> PREFS
    SW -.->|reads cached JSON| PREFS
    DRW -.->|reads cached JSON| PREFS

    style API fill:#4A90D9,color:#fff
    style SYNC fill:#1a1a2e,color:#fff
    style ORCH fill:#16213e,color:#fff
    style NOTIF fill:#0f3460,color:#fff
    style AUDIO fill:#533483,color:#fff
    style PERMS fill:#2d6a4f,color:#fff
    style PREFS fill:#e9c46a,color:#000
```
